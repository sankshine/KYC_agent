ANTHROPIC_API_KEY=your_anthropic_api_key_here
REDIS_URL=redis://localhost:6379
DATABASE_URL=postgresql://user:password@localhost:5432/kyc_review
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET=kyc-documents-bucket
SQS_QUEUE_URL=https://sqs.ca-central-1.amazonaws.com/account/kyc-review-queue
SNS_FRAUD_TOPIC_ARN=arn:aws:sns:ca-central-1:account:kyc-fraud-alerts
ENVIRONMENT=development
AUTO_APPROVE_THRESHOLD=0.95
ESCALATE_THRESHOLD=0.50
