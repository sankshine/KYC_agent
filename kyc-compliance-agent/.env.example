# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# GCP
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=northamerica-northeast1
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# GCS
GCS_BUCKET_NAME=kyc-review-documents

# Pub/Sub (replaces SQS)
PUBSUB_TOPIC_ID=kyc-review-submissions
PUBSUB_SUBSCRIPTION_ID=kyc-review-worker-sub
PUBSUB_FRAUD_TOPIC_ID=kyc-fraud-alerts

# Cloud SQL (PostgreSQL) — replaces RDS
DATABASE_URL=postgresql://user:password@/kyc_review?host=/cloudsql/project:region:instance

# Memorystore Redis — replaces ElastiCache
REDIS_URL=redis://10.0.0.x:6379

# Secret Manager
SECRET_NAME=projects/your-project/secrets/anthropic-api-key/versions/latest

# App
ENVIRONMENT=development
AUTO_APPROVE_THRESHOLD=0.95
ESCALATE_THRESHOLD=0.50
